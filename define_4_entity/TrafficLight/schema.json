{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://smartdatamodels.org/dataModel.SmartTraffic/TrafficLight/schema.json",
    "title": "Smart Traffic - TrafficLight",
    "description": "Schema kiểm duyệt cho thực thể Đèn tín hiệu",
    "type": "object",
    "required": ["id", "type", "direction", "refIntersection"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^urn:ngsi-ld:TrafficLight:.*$"
      },
      "type": {
        "type": "string",
        "enum": ["TrafficLight"]
      },
      "direction": {
        "type": "string",
        "enum": ["North", "South", "East", "West"]
      },
      "color": {
        "type": "string",
        "enum": ["red", "green", "yellow"]
      },
      "remainingSeconds": { "type": "integer", "minimum": 0 },
      "currentPhase": { "type": "string" },
      "nextPhase": { "type": "string" },
      "greenDuration": { "type": "integer", "minimum": 0 },
      "yellowDuration": { "type": "integer", "minimum": 0 },
      "redDuration": { "type": "integer", "minimum": 0 },
      "mode": {
        "type": "string",
        "enum": ["AUTO", "MANUAL"]
      },
      "refIntersection": {
        "type": "string",
        "format": "uri",
        "pattern": "^urn:ngsi-ld:Intersection:.*$"
      }
    }
  }