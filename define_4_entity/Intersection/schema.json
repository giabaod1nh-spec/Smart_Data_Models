{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://smartdatamodels.org/dataModel.SmartTraffic/Intersection/schema.json",
  "title": "Smart Traffic - Intersection",
  "description": "Schema cho thực thể Giao lộ",
  "type": "object",
  "required": ["id", "type", "location", "name"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:ngsi-ld:Intersection:.*$"
    },
    "type": {
      "type": "string",
      "enum": ["Intersection"]
    },
    "name": { "type": "string" },
    "location": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Point"] },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "number" }
        }
      },
      "required": ["type", "coordinates"]
    },
    "status": { "type": "string" },
    "totalVehicleCount": { "type": "integer", "minimum": 0 },
    "averageSpeed": { "type": "number", "minimum": 0 },
    "totalQueueLength": { "type": "number", "minimum": 0 },
    "density": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "currentPhase": { "type": "string" },
    "nextPhase": { "type": "string" },
    "phaseRemainingSeconds": { "type": "integer", "minimum": 0 },
    "phaseDuration": { "type": "integer", "minimum": 0 },
    "incidentDetected": { "type": "boolean" },
    "incidentCount": { "type": "integer", "minimum": 0 },
    "incidentDirection": { "type": "string" },
    "scenario": { "type": "string" },
    "lastUpdate": { "type": "string", "format": "date-time" }
  }
}