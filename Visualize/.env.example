# Copy to .env or set in PowerShell before running.

# Required for TraCI Python bindings + binaries
SUMO_HOME=D:\SUMO

# Orion NGSI-LD broker
ORION_URL=http://localhost:1026

# true → sumo-gui, false → sumo (headless)
SUMO_GUI=true

# Path to sumocfg (default: Visualize/Visualize/intersection.sumocfg)
# SUMO_CONFIG=D:\path\to\intersection.sumocfg

# Override SUMO step length (seconds). Omit to keep sumocfg value (0.01).
# SUMO_STEP_LENGTH=0.1

# Publish every N seconds of *simulation time* (not wall clock)
PUBLISH_INTERVAL=1.0

# NGSI node id to publish (v1: A ↔ SUMO TLS J1)
PUBLISH_NODE=A

LOG_LEVEL=INFO

# PCU used when an unknown SUMO vType appears
PCU_FALLBACK=1.0
