    <!-- Loại xe + sprite PNG (đường dẫn tương đối so với sumocfg) -->
    <vType id="motorcycle" vClass="motorcycle" guiShape="motorcycle" length="2.0" width="0.9" maxSpeed="16.7" accel="3.0" decel="5.0" sigma="0.5" minGap="0.5" speedFactor="1.1" impatience="0.4" lcStrategic="1.2" lcSpeedGain="1.2" lcKeepRight="0.5" imgFile="images/bike_bg.png"/>
