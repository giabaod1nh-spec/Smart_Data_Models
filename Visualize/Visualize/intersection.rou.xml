    <vType id="bus" vClass="bus" guiShape="bus" length="12.0" width="2.8" maxSpeed="11.0" accel="1.5" decel="3.5" sigma="0.5" minGap="3.0" imgFile="images/bus_bg.png"/>
    <vType id="truck" vClass="truck" guiShape="truck" length="7.1" width="2.4" maxSpeed="11.1" accel="1.2" decel="3.0" sigma="0.5" minGap="3.0" imgFile="images/truck_bg.png"/>
